generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ApiKey {
  id        String    @id @default(uuid())
  name      String    @unique
  keyHash   String    @unique
  salt      String
  scopes    String[]
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  revokedAt DateTime?

  @@map("api_keys")
}

model ProcessedEvent {
  id        String   @id
  createdAt DateTime @default(now())

  @@map("processed_events")
}

model SupplierRevenue {
  supplierId String   @id
  balance    Decimal  @default(0) @db.Decimal(20, 2)
  updatedAt  DateTime @updatedAt

  @@map("supplier_revenues")
}

model RevenueAuditLog {
  id              String   @id @default(uuid())
  supplierId      String
  invoiceId       String
  correlationId   String
  amount          Decimal  @db.Decimal(20, 2)
  previousBalance Decimal  @db.Decimal(20, 2)
  newBalance      Decimal  @db.Decimal(20, 2)
  createdAt       DateTime @default(now())

  @@index([supplierId], map: "idx_revenue_audit_logs_supplierId")
  @@index([correlationId], map: "idx_revenue_audit_logs_correlationId")
  @@map("revenue_audit_logs")
}
